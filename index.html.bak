<script>
// ═══════════════════════════════════════════════
// i18n — English / Russian language switcher
// ═══════════════════════════════════════════════

const I18N = {
  en: {
    title: "Fluency Bridge — Master English, Your Way",
    nav_beginners: "Beginners",
