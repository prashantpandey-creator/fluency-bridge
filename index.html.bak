let currentLang = localStorage.getItem('fb_lang') || 'en';

function switchLang(lang) {
  currentLang = lang;
  localStorage.setItem('fb_lang', lang);
  document.documentElement.lang = lang === 'ru' ? 'ru' : 'en';

  // Update buttons
  document.getElementById('langEn').classList.toggle('nav__lang-btn--active', lang === 'en');
  document.getElementById('langRu').classList.toggle('nav__lang-btn--active', lang === 'ru');

  // Update all i18n elements
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (I18N[lang] && I18N[lang][key]) {
      if (el.tagName === 'TITLE') {
        document.title = I18N[lang][key];
      } else if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
        el.placeholder = I18N[lang][key];
      } else if (el.tagName === 'SELECT') {
        // Update select options
      } else if (el.tagName === 'BUTTON' || el.childNodes.length <= 1) {
        el.textContent = I18N[lang][key];
      }
    }
  });

  // Update select options
  const sel = document.querySelector('select[data-i18n-select]');
  if (sel) {
    const prefix = sel.getAttribute('data-i18n-select');
    sel.options[0].textContent = I18N[lang][prefix + '_beginner'] || sel.options[0].textContent;
    sel.options[1].textContent = I18N[lang][prefix + '_young'] || sel.options[1].textContent;
    sel.options[2].textContent = I18N[lang][prefix + '_adult'] || sel.options[2].textContent;
    sel.options[3].textContent = I18N[lang][prefix + '_intermediate'] || sel.options[3].textContent;
  }
}

// Init on load
document.addEventListener('DOMContentLoaded', () => {
  switchLang(currentLang);
});
</script>

<script src="app.js"></script>
</body>
</html>
